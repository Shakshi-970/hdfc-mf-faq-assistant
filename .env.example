# Mutual Fund FAQ Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — add it to .gitignore.

# ---------------------------------------------------------------------------
# Anthropic Claude API  (required — used by pipeline.py for LLM generation)
# Get from: https://console.anthropic.com/account/keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Chroma Cloud  (required — used by upsert.py and retriever.py)
# Get from: https://trychroma.com  →  your tenant dashboard
# ---------------------------------------------------------------------------
CHROMA_API_KEY=ck-DX479QDHPAta87dCXmF6NG5jL6a1PnnikUAhMaAqbnWB
CHROMA_TENANT=1f98fd08-3154-4c37-be62-4d116e515183
CHROMA_DATABASE=Demo

# ---------------------------------------------------------------------------
# Groq API  (required for Phase 6 — used by GroqClient when LLM_PROVIDER=groq)
# Get a free key from: https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_...

# LLM provider selection (Phase 6 only)  — "groq" (default) or "claude"
# LLM_PROVIDER=groq
# GROQ_MODEL=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# Redis Session Backend  (optional — leave unset to use in-memory sessions)
# Set this only for production / multi-instance deployments.
# Example: redis://localhost:6379/0
#          redis://:password@redis-host:6379/0
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Session TTL  (optional — default is 1800 seconds = 30 minutes)
# ---------------------------------------------------------------------------
# SESSION_TTL_SECONDS=1800
