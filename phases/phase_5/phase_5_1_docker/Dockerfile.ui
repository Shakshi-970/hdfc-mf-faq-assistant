# Mutual Fund FAQ Assistant — Streamlit UI
# Build context: repo root
#
# Build:
#   docker build -f phases/phase_5/phase_5_1_docker/Dockerfile.ui -t mf-faq-ui .
#
# Run:
#   docker run -p 8501:8501 \
#     -e API_BASE_URL=http://backend:8000 \
#     mf-faq-ui

FROM python:3.11-slim

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source
COPY phases/ ./phases/

EXPOSE 8501

# Streamlit server config — required for containerised / headless deployment
ENV STREAMLIT_SERVER_PORT=8501
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Start the Streamlit UI
CMD ["python", "-m", "phases.phase_3.phase_3_6_ui"]
